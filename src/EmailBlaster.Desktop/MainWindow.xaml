<Window x:Class="EmailBlaster.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Email Blaster" Height="820" Width="1240"
        MinHeight="640" MinWidth="1040"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Sidebar navigation item -->
        <Style x:Key="NavButton" TargetType="RadioButton">
            <Setter Property="GroupName" Value="Nav" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Margin" Value="10,2" />
            <Setter Property="Foreground" Value="#CBD5E1" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" CornerRadius="8" Background="Transparent" Padding="12,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="icon" FontFamily="Segoe MDL2 Assets"
                                           Text="{TemplateBinding Tag}" FontSize="16"
                                           VerticalAlignment="Center" Width="26"
                                           Foreground="{TemplateBinding Foreground}" />
                                <ContentPresenter VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1E293B" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===================== Sidebar ===================== -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}">
            <DockPanel>
                <!-- Brand -->
                <StackPanel DockPanel.Dock="Top" Margin="22,24,20,20">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="34" Height="34" CornerRadius="8" Background="{DynamicResource AccentBrush}">
                            <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" FontSize="17"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Email Blaster" Foreground="White" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="Bulk messaging" Foreground="#64748B" FontSize="11" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Status footer -->
                <StackPanel DockPanel.Dock="Bottom" Margin="20,0,20,20">
                    <Button x:Name="ThemeToggle" Height="32" Margin="0,0,0,12" Cursor="Hand"
                            Foreground="#E2E8F0" FontSize="12.5" Click="ThemeToggle_Click"
                            ToolTip="Toggle light / dark theme">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="7" Background="#1E293B">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#334155" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Border Height="1" Background="#1E293B" Margin="0,0,0,14" />
                    <TextBlock x:Name="StatusProvider" Text="Provider: SMTP" Foreground="#94A3B8" FontSize="11.5" />
                    <TextBlock x:Name="StatusRecipients" Text="0 recipients loaded" Foreground="#94A3B8"
                               FontSize="11.5" Margin="0,4,0,0" />
                </StackPanel>

                <!-- Nav items -->
                <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">
                    <RadioButton x:Name="NavConfig" Style="{StaticResource NavButton}" Tag="&#xE713;"
                                 Content="Configuration" IsChecked="True" Checked="Nav_Checked" />
                    <RadioButton x:Name="NavRecipients" Style="{StaticResource NavButton}" Tag="&#xE716;"
                                 Content="Recipients" Checked="Nav_Checked" />
                    <RadioButton x:Name="NavCompose" Style="{StaticResource NavButton}" Tag="&#xE70F;"
                                 Content="Compose" Checked="Nav_Checked" />
                    <RadioButton x:Name="NavPreview" Style="{StaticResource NavButton}" Tag="&#xE890;"
                                 Content="Preview" Checked="Nav_Checked" />
                    <RadioButton x:Name="NavSend" Style="{StaticResource NavButton}" Tag="&#xE724;"
                                 Content="Send" Checked="Nav_Checked" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===================== Content ===================== -->
        <ContentControl x:Name="MainContent" Grid.Column="1" Margin="0" />
    </Grid>
</Window>

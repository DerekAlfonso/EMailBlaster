<UserControl x:Class="EmailBlaster.Desktop.Views.ComposeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             FontFamily="Segoe UI">
    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="28,20">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Compose" Style="{StaticResource H1}" />
                    <TextBlock Text="Design your HTML message and drop in personalisation placeholders."
                               Style="{StaticResource Subtle}" />
                </StackPanel>
                <Button x:Name="ToggleSourceButton" Content="Edit HTML source" DockPanel.Dock="Right"
                        Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right"
                        VerticalAlignment="Center" Click="ToggleSource_Click" />
            </DockPanel>
        </Border>

        <Grid Margin="28,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Subject -->
            <StackPanel Grid.Row="0" Margin="0,0,0,14">
                <TextBlock Text="Subject" Style="{StaticResource FieldLabel}" />
                <TextBox x:Name="SubjectBox" GotKeyboardFocus="Subject_GotFocus"
                         TextChanged="Subject_TextChanged" />
            </StackPanel>

            <!-- Placeholder chips -->
            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="14,12" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Insert placeholder (click to add at the cursor)"
                               Style="{StaticResource FieldLabel}" Margin="0,0,0,8" />
                    <WrapPanel x:Name="PlaceholderPanel" />
                </StackPanel>
            </Border>

            <!-- Editor -->
            <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    CornerRadius="10" Background="White" ClipToBounds="True">
                <Grid>
                    <wv2:WebView2 x:Name="Editor" />
                    <TextBox x:Name="SourceBox" Style="{StaticResource MultilineTextBox}"
                             Visibility="Collapsed" BorderThickness="0" Padding="14"
                             VerticalScrollBarVisibility="Auto" TextChanged="Source_TextChanged" />
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>

<UserControl x:Class="EmailBlaster.Desktop.Views.SendView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="28,20">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Send" Style="{StaticResource H1}" />
                    <TextBlock Text="Review the run, then start sending. Progress updates live."
                               Style="{StaticResource Subtle}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="CancelButton" Content="Cancel" Style="{StaticResource SecondaryButton}"
                            Margin="0,0,10,0" IsEnabled="False" Click="Cancel_Click" />
                    <Button x:Name="StartButton" Content="Start sending" Style="{StaticResource PrimaryButton}"
                            Click="Start_Click" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Margin="28,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Pre-flight summary -->
            <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,14">
                <UniformGrid Rows="1" Columns="4">
                    <StackPanel>
                        <TextBlock Text="Recipients" Style="{StaticResource Subtle}" />
                        <TextBlock x:Name="SummaryRecipients" Text="0" FontSize="22" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Provider" Style="{StaticResource Subtle}" />
                        <TextBlock x:Name="SummaryProvider" Text="SMTP" FontSize="22" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Send rate" Style="{StaticResource Subtle}" />
                        <TextBlock x:Name="SummaryRate" Text="5 / sec" FontSize="22" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="From" Style="{StaticResource Subtle}" />
                        <TextBlock x:Name="SummaryFrom" Text="—" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" Margin="0,6,0,0" />
                    </StackPanel>
                </UniformGrid>
            </Border>

            <!-- Progress -->
            <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,14">
                <StackPanel>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock x:Name="ProgressLabel" Text="Idle" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" />
                        <TextBlock x:Name="ProgressCounts" Text="" HorizontalAlignment="Right"
                                   Style="{StaticResource Subtle}" />
                    </DockPanel>
                    <ProgressBar x:Name="Progress" Height="10" Minimum="0" Maximum="100" Value="0"
                                 Background="{DynamicResource TrackBrush}" Foreground="{DynamicResource AccentBrush}"
                                 BorderThickness="0" />
                </StackPanel>
            </Border>

            <!-- Log -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
                <DataGrid x:Name="LogGrid" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
                        <DataGridTextColumn Header="Recipient" Binding="{Binding Email}" Width="2*" />
                        <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="3*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>

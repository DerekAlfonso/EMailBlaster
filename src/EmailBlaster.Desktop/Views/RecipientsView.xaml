<UserControl x:Class="EmailBlaster.Desktop.Views.RecipientsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="28,20">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Recipients" Style="{StaticResource H1}" />
                    <TextBlock Text="Import an audience from CSV or Excel. Columns become merge placeholders."
                               Style="{StaticResource Subtle}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="ClearButton" Content="Clear" Style="{StaticResource SecondaryButton}"
                            Margin="0,0,10,0" Click="Clear_Click" />
                    <Button x:Name="ImportButton" Content="Import file…" Style="{StaticResource PrimaryButton}"
                            Click="Import_Click" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Margin="28,22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Summary / columns -->
            <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="SummaryText" Text="No recipients loaded yet."
                                   Style="{StaticResource SectionHeader}" Margin="0" />
                    </StackPanel>
                    <TextBlock Text="Available placeholders" Style="{StaticResource FieldLabel}" Margin="0,14,0,6" />
                    <WrapPanel x:Name="ColumnChips" />
                </StackPanel>
            </Border>

            <!-- Grid -->
            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <DataGrid x:Name="RecipientsGrid" BorderThickness="0" />
                    <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="42"
                                   Foreground="#CBD5E1" HorizontalAlignment="Center" />
                        <TextBlock Text="Import a CSV or XLSX to get started"
                                   Style="{StaticResource Subtle}" Margin="0,10,0,0" HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>

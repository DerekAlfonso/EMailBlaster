<UserControl x:Class="EmailBlaster.Desktop.Views.PreviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             FontFamily="Segoe UI">
    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="28,20">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Preview" Style="{StaticResource H1}" />
                    <TextBlock Text="See exactly how each merged message will look before you send."
                               Style="{StaticResource Subtle}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="PrevButton" Content="&#xE76B;" FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource SecondaryButton}" MinWidth="42" Click="Prev_Click" />
                    <ComboBox x:Name="RecipientSelector" Width="300" Margin="10,0"
                              SelectionChanged="Recipient_Changed" />
                    <Button x:Name="NextButton" Content="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource SecondaryButton}" MinWidth="42" Click="Next_Click" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Margin="28,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Envelope -->
            <Border Grid.Row="0" Style="{StaticResource Card}" Padding="18,14" Margin="0,0,0,14">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="To" Style="{StaticResource Subtle}" />
                        <TextBlock x:Name="ToText" Grid.Column="1" FontSize="13"
                                   Foreground="{DynamicResource TextBrush}" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Subject" Style="{StaticResource Subtle}" />
                        <TextBlock x:Name="SubjectText" Grid.Column="1" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Rendered body -->
            <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    CornerRadius="10" Background="White" ClipToBounds="True">
                <wv2:WebView2 x:Name="PreviewBrowser" />
            </Border>
        </Grid>
    </DockPanel>
</UserControl>

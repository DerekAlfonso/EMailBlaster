<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Light palette. Same keys as Palette.Dark.xaml — ThemeManager swaps whole dictionaries at
         runtime and DynamicResource references re-resolve live. Keep both palettes in sync. -->
    <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#1D4ED8" />
    <SolidColorBrush x:Key="SidebarBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F1F5F9" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="BorderBrush" Color="#E2E8F0" />
    <SolidColorBrush x:Key="TextBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#64748B" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A" />
    <SolidColorBrush x:Key="DangerBrush" Color="#DC2626" />

    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="InputDisabledBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="HoverBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="HoverBorderBrush" Color="#CBD5E1" />
    <SolidColorBrush x:Key="DisabledAccentBrush" Color="#93C5FD" />
    <SolidColorBrush x:Key="ChipBrush" Color="#EEF2FF" />
    <SolidColorBrush x:Key="ChipHoverBrush" Color="#E0E7FF" />
    <SolidColorBrush x:Key="ChipTextBrush" Color="#1D4ED8" />
    <SolidColorBrush x:Key="AltRowBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="ColumnHeaderBrush" Color="#F1F5F9" />
    <SolidColorBrush x:Key="TrackBrush" Color="#EEF2F7" />
    <SolidColorBrush x:Key="StatusOkBackgroundBrush" Color="#F0FDF4" />
    <SolidColorBrush x:Key="StatusErrBackgroundBrush" Color="#FEF2F2" />
</ResourceDictionary>
